Special:<class 'str'>
Misc:<class 'str'>
Desc:<class 'str'>
desc: 'Your eidolon has more evolutions.',
Prerequisite:<class 'str'>
Benefit:<class 'str'>
Special:<class 'str'>
Name:<class 'str'>
name: 'Extra Evolution',
