name: 'Neither Elf nor Human',
Prerequisites<class 'str'>
Desc:<class 'str'>
desc: 'Your anonymity makes you difficult to find through magical or mundane means, and you have learned how to combat both of your progenitor races.',
Benefit<class 'str'>
Misc:<class 'str'>
Name:<class 'str'>
name: 'Seen and Unseen',
